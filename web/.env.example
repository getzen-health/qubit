NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
USDA_API_KEY=your_usda_api_key_here
# Secret passphrase used to AES-256-GCM-encrypt user API keys at rest.
# Generate with: openssl rand -hex 32
API_KEY_ENCRYPTION_SECRET=your-strong-random-secret-here

# ===== OAuth Token Encryption =====
# 32-byte hex key for AES-256-GCM encryption of OAuth tokens (e.g., Strava tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ===== Configuration Limits =====
# These values control API limits, input validation, and data retrieval constraints.
# Adjust based on your server capacity and user needs.

# API Request/Response Limits
MAX_CHAT_MESSAGES=50
MAX_CONTENT_LENGTH=5000
MAX_SYSTEM_PROMPT_LENGTH=2000
MAX_API_KEY_LENGTH=500

# Food/Nutrition API Limits
MAX_SEARCH_PAGE_SIZE=20
MAX_SEARCH_PAGE=100
MAX_FOOD_NAME_LENGTH=200
MAX_CALORIES=10000
MAX_MACRONUTRIENT_G=1000
MAX_MEAL_NOTE_LENGTH=500
MAX_BARCODE_LENGTH=14
MAX_PRODUCT_NAME_LENGTH=255
MAX_FOOD_HISTORY_LIMIT=50
DEFAULT_FOOD_HISTORY_LIMIT=20

# Workout/Activity Limits
MAX_WORKOUTS_LIMIT=100
DEFAULT_WORKOUTS_LIMIT=30

# Health Data Limits
MAX_GLUCOSE_SAMPLES=288
MAX_HISTORY_DAYS=365
DEFAULT_HISTORY_DAYS=30
MAX_FASTING_RECORDS_LIMIT=50
DEFAULT_FASTING_RECORDS_LIMIT=10
MAX_CHECKIN_DAYS=90

# File Upload Limits
MAX_FILE_SIZE_BYTES=52428800

# Validation Limits
MAX_STRING_LENGTH=500
MAX_TITLE_LENGTH=120
MAX_CATEGORY_LENGTH=100
MIN_CATEGORY_LENGTH=2
