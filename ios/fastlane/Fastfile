default_platform(:ios)

platform :ios do
  desc "Run tests"
  lane :tests do
    run_tests(
      project: "KQuarks.xcodeproj",
      scheme: "KQuarks",
      devices: ["iPhone 16"]
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: "KQuarks.xcodeproj")
    build_app(
      project: "KQuarks.xcodeproj",
      scheme: "KQuarks",
      export_method: "app-store"
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Upload to App Store"
  lane :release do
    increment_build_number(xcodeproj: "KQuarks.xcodeproj")
    build_app(
      project: "KQuarks.xcodeproj",
      scheme: "KQuarks",
      export_method: "app-store"
    )
    upload_to_app_store(
      force: true,
      reject_if_possible: true,
      skip_screenshots: false,
      skip_metadata: false
    )
  end
  
  desc "Take screenshots"
  lane :screenshots do
    capture_screenshots(scheme: "KQuarksUITests")
    frame_screenshots(white: true)
  end
end
